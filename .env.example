# ============================================================
# SafetyGuard X — Environment Configuration
# ============================================================

# Server Mode
PORT=7860
DEBUG=false

# --- Basilisk Red-Teamer (v3.0) ---
# Supported models: "mock", "claude-3-5-sonnet-20240620", "gpt-4o", "grok-1"
REDTEAMER_MODEL=mock
REDTEAMER_TEMPERATURE=0.9
REDTEAMER_VARIATION=medium

# LLM API Keys (Only if REDTEAMER_MODEL != "mock")
# ANTHROPIC_API_KEY=your_key_here
# OPENAI_API_KEY=your_key_here
# XAI_API_KEY=your_key_here

# --- RL Training Settings ---
STABLE_BASELINES_LOGS=./logs/
DATASET_EXPORT_DIR=./exports/datasets/
MODEL_EXPORT_DIR=./exports/models/
